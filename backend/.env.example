# ═══════════════════════════════════════════════════════════
# THE SECRET — Backend Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this to .env and fill in your values.
# NEVER commit .env to git!

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────
# Local: mongodb://localhost:27017/the-secret
# Production (Atlas): mongodb+srv://USER:PASS@cluster.mongodb.net/the-secret
MONGO_URI=mongodb://localhost:27017/the-secret

# ── Authentication ────────────────────────────────────────
# IMPORTANT: Use a random 64+ character string! NOT your Mongo URI!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_random_jwt_secret_here
JWT_EXPIRE=7d

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here

# ── CORS / Frontend URL ──────────────────────────────────
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
# Multiple origins: https://your-app.vercel.app,http://localhost:3000
CLIENT_URL=http://localhost:3000

# ── Redis (OPTIONAL) ─────────────────────────────────────
# If not set, Redis features degrade gracefully (no caching,
# presence, batching — but the app still works).
# Free providers: Upstash (https://upstash.com), Redis Cloud
# REDIS_URL=redis://default:password@host:port

# ── AI Moderation (optional — falls back to heuristic scoring)
# OPENAI_API_KEY=your_openai_api_key_here
